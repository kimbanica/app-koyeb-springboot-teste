# Exemplo para quando for conectar ao MySQL externo.
# Copie estas linhas para src/main/resources/application.properties
# somente depois que o teste simples do Koyeb estiver funcionando.

server.port=${PORT:8080}

spring.datasource.url=jdbc:mysql://${DB_HOST}:${DB_PORT}/${DB_NAME}?useSSL=true&serverTimezone=UTC
spring.datasource.username=${DB_USER}
spring.datasource.password=${DB_PASSWORD}

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

# Para banco gratuito com poucas conexões, mantenha baixo:
spring.datasource.hikari.maximum-pool-size=2
